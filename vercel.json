{
  "redirects": [
    { "source": "/lumier",                  "destination": "/prodotti/lumier",          "permanent": true },
    { "source": "/lumier/",                 "destination": "/prodotti/lumier",          "permanent": true },
    { "source": "/tempra",                  "destination": "/prodotti/alum",            "permanent": true },
    { "source": "/tempra/",                 "destination": "/prodotti/alum",            "permanent": true },
    { "source": "/skywood",                 "destination": "/prodotti/legno-alluminio", "permanent": true },
    { "source": "/skywood/",                "destination": "/prodotti/legno-alluminio", "permanent": true },
    { "source": "/urban",                   "destination": "/prodotti",                 "permanent": true },
    { "source": "/urban/",                  "destination": "/prodotti",                 "permanent": true },
    { "source": "/idole",                   "destination": "/prodotti/idole",           "permanent": true },
    { "source": "/idole/",                  "destination": "/prodotti/idole",           "permanent": true },
    { "source": "/persiane",                "destination": "/prodotti/persiane",        "permanent": true },
    { "source": "/persiane/",               "destination": "/prodotti/persiane",        "permanent": true },
    { "source": "/persiane-in-alluminio",   "destination": "/prodotti/persiane",        "permanent": true },
    { "source": "/persiane-in-alluminio/",  "destination": "/prodotti/persiane",        "permanent": true },
    { "source": "/blog",                    "destination": "/articoli",                 "permanent": true },
    { "source": "/blog/",                   "destination": "/articoli",                 "permanent": true },
    { "source": "/blog/:slug*",             "destination": "/articoli",                 "permanent": true },
    { "source": "/home-page",               "destination": "/",                         "permanent": true },
    { "source": "/home-page/",              "destination": "/",                         "permanent": true }
  ],
  "rewrites": [
    { "source": "/((?!api/|assets/|.*\\..*).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|webp|svg|ico|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" },
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" },
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}
